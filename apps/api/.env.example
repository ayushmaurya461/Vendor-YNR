NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/ynr-local
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Comma-separated; Capacitor Android (https://localhost) is allowed automatically in development
FRONTEND_ORIGIN=http://localhost:4200

# Production: get real values from https://console.cloudinary.com → Dashboard (API Keys)
# Development: photos save to apps/api/uploads/ by default (Cloudinary creds are ignored)
# To test Cloudinary locally: MEDIA_UPLOAD=cloudinary
MEDIA_UPLOAD=auto
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Local dev without SMS: set true and OTP is printed in the API console
OTP_LOG_ONLY=true
